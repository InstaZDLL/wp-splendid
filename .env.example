# ── Base de données ───────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ── WordPress Salts ───────────────────────────────────────────────
# Générer sur : https://api.wordpress.org/secret-key/1.1/salt/
WP_AUTH_KEY=put_a_random_string_here
WP_SECURE_AUTH_KEY=put_a_random_string_here
WP_LOGGED_IN_KEY=put_a_random_string_here
WP_NONCE_KEY=put_a_random_string_here
WP_AUTH_SALT=put_a_random_string_here
WP_SECURE_AUTH_SALT=put_a_random_string_here
WP_LOGGED_IN_SALT=put_a_random_string_here
WP_NONCE_SALT=put_a_random_string_here
