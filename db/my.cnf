[mysqld]
# ── Charset ───────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── InnoDB Buffer Pool ────────────────────────────────────────────
# Règle générale : 70-80% de la RAM disponible pour le conteneur
# Ajuste selon la RAM allouée à Docker
innodb_buffer_pool_size       = 512M
innodb_buffer_pool_instances  = 2       # 1 instance par 1 Go de buffer pool

# ── Redo Log (remplace innodb_log_file_size depuis MySQL 8.0.30) ──
innodb_redo_log_capacity      = 512M    # = innodb_log_file_size * innodb_log_files_in_group

# ── Flush & Durabilité ────────────────────────────────────────────
# 2 = écriture log à chaque commit mais flush disque 1x/sec (meilleur perf)
# 1 = ACID complet (plus sûr, plus lent) — mets 1 en production critique
innodb_flush_log_at_trx_commit = 2
innodb_flush_method            = O_DIRECT  # Évite double buffering OS/InnoDB

# ── Tables temporaires ────────────────────────────────────────────
tmp_table_size        = 128M
max_heap_table_size   = 128M

# ── Paquets & Connexions ──────────────────────────────────────────
max_allowed_packet    = 256M
max_connections       = 100     # WordPress ne nécessite pas 200, 100 suffit

# ── Timeouts ─────────────────────────────────────────────────────
wait_timeout          = 300
interactive_timeout   = 300

# ── Slow Query Log ────────────────────────────────────────────────
slow_query_log        = 1
slow_query_log_file   = /var/lib/mysql/slow.log
long_query_time       = 2

# ── Divers ───────────────────────────────────────────────────────
bulk_insert_buffer_size = 64M
table_open_cache        = 400
thread_cache_size       = 8